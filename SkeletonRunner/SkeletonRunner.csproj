<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <UseWindowsForms>true</UseWindowsForms>
    <ImplicitUsings>enable</ImplicitUsings>
    <StartupObject>SkeletonRunner.Program</StartupObject>
  </PropertyGroup>

  <ItemGroup>
    <None Remove="assets\skeleton.gif" />
    <None Remove="assets\skeleton.png" />
    <None Remove="assets\skeleton.wav" />
  </ItemGroup>

  <ItemGroup>
    <Content Include="assets\skeleton.gif">
      <CopyToOutputDirectory>Always</CopyToOutputDirectory>
    </Content>
    <Content Include="assets\skeleton.png">
      <CopyToOutputDirectory>Always</CopyToOutputDirectory>
    </Content>
    <Content Include="assets\skeleton.wav">
      <CopyToOutputDirectory>Always</CopyToOutputDirectory>
    </Content>
  </ItemGroup>

</Project>